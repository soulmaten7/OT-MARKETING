# STEP_65 — 블로그문자 SaaS 환경변수 템플릿
# 사장 작업: supabase.com 에서 "OTMarketing-blog-sms" 프로젝트 생성 후 박기

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# 사이트 base URL (OAuth callback 용)
NEXT_PUBLIC_SITE_URL=https://ot-marketing.kr

# STEP_108 — 사이트 모드 플래그
# production = cpa_only (CPA 광고만 노출, 나머지 /cpa redirect)
# 로컬 개발 = full (전체 페이지 노출)
NEXT_PUBLIC_SITE_MODE=full

# STEP_105 — 개발 모드 인증 우회 (로컬 개발 시 true, production = 비워두거나 false)
NEXT_PUBLIC_DEV_BYPASS_AUTH=true
